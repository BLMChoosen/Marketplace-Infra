# ──────────────────────────────────────────
# Marketplace Infra — Environment Variables
# Copy this file to .env and fill in values.
# Used by docker-compose to configure the
# shared infrastructure services.
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_secret
POSTGRES_DB=marketplace_db
POSTGRES_PORT=5432

# PostgreSQL (Testing)
TEST_POSTGRES_USER=marketplace_test
TEST_POSTGRES_PASSWORD=marketplace_test_secret
TEST_POSTGRES_DB=marketplace_test_db
TEST_POSTGRES_PORT=5433

# Redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# MongoDB Atlas (chat)
# Atlas is managed outside docker-compose. Put the same values in
# Marketplace-Backend/.env for the Flask API and Socket.IO chat service.
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=marketplace_chat

# Elasticsearch
ELASTICSEARCH_PORT=9200

# RabbitMQ
RABBITMQ_USER=marketplace
RABBITMQ_PASSWORD=rabbitmq_secret
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Nginx
NGINX_PORT=80

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret
