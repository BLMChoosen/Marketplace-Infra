# ──────────────────────────────────────────
# Marketplace Infra — Environment Variables
# Copy this file to .env and fill in values.
# Used by docker-compose to configure the
# shared infrastructure services.
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_secret
POSTGRES_DB=marketplace_db
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# Elasticsearch
ELASTICSEARCH_PORT=9200

# RabbitMQ
RABBITMQ_USER=marketplace
RABBITMQ_PASSWORD=rabbitmq_secret
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Nginx
NGINX_PORT=80

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret
