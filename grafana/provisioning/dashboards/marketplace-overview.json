{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Requests / sec",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx error rate",
      "datasource": "Prometheus",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request latency p95 (s)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["marketplace"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "",
  "title": "Marketplace Overview",
  "uid": "marketplace-overview",
  "version": 1
}
